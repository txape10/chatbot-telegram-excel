# ════════════════════════════════════════════════════════════════════════════
#  excel-addin/.env.empresa.example — Variables para compilar el Add-in en empresa
#  Copiar a excel-addin/.env, rellenar y luego ejecutar: npm run build
#  Este fichero SÍ va al repositorio; el .env real NO (está en .gitignore).
# ════════════════════════════════════════════════════════════════════════════

# URL pública del servidor donde está desplegada la API del backend
# Ejemplos:
#   https://asistente.empresa.eu/       ← servidor propio con cloudflared
#   https://asistente-excel.onrender.com/  ← Render cloud
ADDIN_URL=https://asistente.empresa.eu/

# Clave de API — debe coincidir exactamente con API_KEY en el .env del backend
API_KEY=misma_clave_que_el_backend

# Modo de autenticación
# whitelist → valida por dominio/correo de Office 365 (sin Azure AD extra)
# sso       → futuro: token Azure AD verificado en backend (requiere app registration)
AUTH_MODE=whitelist

# Dominios corporativos con acceso (todos los usuarios del dominio en Office 365)
ALLOWED_DOMAINS=empresa.eu,empresa.com

# Correos individuales adicionales (opcionales)
ALLOWED_EMAILS=

# Nombre de la empresa — aparece en el tema "Empresa" del selector de temas
COMPANY_NAME=Mi Empresa
