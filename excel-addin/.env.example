# Modo de autenticación del Add-in
# whitelist → auth.whitelist.js (sin Azure AD, listo para usar)
# sso       → auth.sso.js      (requiere app registrada en Azure AD)
AUTH_MODE=whitelist

# Whitelist de acceso (solo para AUTH_MODE=whitelist)
# Separados por comas, sin espacios
ALLOWED_DOMAINS=tuempresa.com,tuempresa.es
ALLOWED_EMAILS=usuario@gmail.com

# URL pública del Add-in en producción (Railway)
ADDIN_URL=https://tu-app.railway.app/
