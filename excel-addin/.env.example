# Variables del Add-in — usadas por webpack en tiempo de build
# Copia este fichero a .env y rellena los valores reales
# .env está en .gitignore y NUNCA se sube al repositorio

# URL pública donde está desplegada la API (con barra final)
# Local:  http://localhost:8000/
# Render: https://asistente-excel.onrender.com/
ADDIN_URL=https://asistente-excel.onrender.com/

# Clave de API (debe coincidir con API_KEY en el .env raíz del proyecto)
# Generar con: python -c "import secrets; print(secrets.token_hex(32))"
API_KEY=

# Control de acceso
AUTH_MODE=whitelist

# Dominios de correo corporativo permitidos (separados por coma)
ALLOWED_DOMAINS=

# Correos individuales permitidos (separados por coma)
ALLOWED_EMAILS=
