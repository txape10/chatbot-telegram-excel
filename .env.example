# ── Módulos ───────────────────────────────────────────────────────────────────
ENABLE_TELEGRAM=true
ENABLE_ADDIN=true

# ── Proveedor de IA ───────────────────────────────────────────────────────────
# groq | ollama | gemini | mistral | openai | azure
LLM_PROVIDER=groq
LLM_MODEL=llama-3.3-70b-versatile

# Groq (LLM_PROVIDER=groq) — gratuito en console.groq.com
GROQ_API_KEY=clave_de_groq

# Proveedor de respaldo — se activa automáticamente si el primario falla
# (rate limit, timeout o error de conexión). Recomendado: mistral (EU, gratis)
# LLM_FALLBACK_PROVIDER=mistral
# LLM_FALLBACK_MODEL=mistral-small-latest   # opcional; si está vacío usa el default del proveedor

# Mistral — free tier en console.mistral.ai (solo verificación de teléfono, sin tarjeta)
# Usar como LLM_FALLBACK_PROVIDER o como proveedor principal en versión empresa (datos en la UE)
# MISTRAL_API_KEY=clave_de_mistral

# Gemini (LLM_PROVIDER=gemini) — gratuito en aistudio.google.com
# GEMINI_API_KEY=clave_de_gemini
# LLM_MODEL=gemini-1.5-flash

# Ollama (LLM_PROVIDER=ollama) — modelo local, sin datos fuera de la red
# OLLAMA_URL=http://localhost:11434
# LLM_MODEL=llama3.2

# OpenAI (LLM_PROVIDER=openai) — de pago
# OPENAI_API_KEY=sk-...

# Azure OpenAI (LLM_PROVIDER=azure) — de pago, datos en la UE, cumple RGPD
# AZURE_OPENAI_KEY=clave_de_azure
# AZURE_OPENAI_URL=https://<recurso>.openai.azure.com
# AZURE_API_VERSION=2024-02-01
# LLM_MODEL=gpt-4o-mini

# ── Bot de Telegram ───────────────────────────────────────────────────────────
# Token obtenido de @BotFather en Telegram
TELEGRAM_TOKEN=token_obtenido_de_botfather
# IDs numéricos de Telegram (obtener con @userinfobot)
AUTHORIZED_USERS=123456789,987654321

# ── Add-in Excel ──────────────────────────────────────────────────────────────
# Generar con: python -c "import secrets; print(secrets.token_hex(32))"
API_KEY=clave_secreta_del_addin
# Dominios corporativos con acceso (todos los correos de ese dominio)
ALLOWED_DOMAINS=empresa.eu,empresa.com
# Correos individuales adicionales
ALLOWED_EMAILS=usuario@gmail.com,otro@outlook.es

# ── Panel de administración ───────────────────────────────────────────────────
# Clave para acceder a /admin y /admin/stats (si está vacía, usa API_KEY)
# Generar con: python -c "import secrets; print(secrets.token_hex(32))"
ADMIN_KEY=

# ── URLs de despliegue ────────────────────────────────────────────────────────
# Local Windows: dejar vacío (el bot usa polling sin webhook)
# Render/cloud:  https://asistente-excel.onrender.com
WEBHOOK_URL=
ADDIN_URL=
