# ── Módulos (true/false) ──────────────────────────────────────────────────────
ENABLE_TELEGRAM=true
ENABLE_ADDIN=true

# ── Proveedor de IA ───────────────────────────────────────────────────────────
# groq | ollama | openai
LLM_PROVIDER=groq
LLM_MODEL=llama-3.3-70b-versatile

# Groq (LLM_PROVIDER=groq) — gratuito en console.groq.com
GROQ_API_KEY=clave_de_groq

# Ollama (LLM_PROVIDER=ollama) — modelo local, sin datos fuera de la red
# OLLAMA_URL=http://localhost:11434
# LLM_MODEL=llama3.2

# OpenAI (LLM_PROVIDER=openai) — de pago
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=           # solo para Azure OpenAI

# ── Bot de Telegram ───────────────────────────────────────────────────────────
TELEGRAM_TOKEN=token_obtenido_de_botfather
AUTHORIZED_USERS=123456789,987654321

# ── Add-in Excel ──────────────────────────────────────────────────────────────
API_KEY=clave_secreta_del_addin
ALLOWED_DOMAINS=launioncorp.eu,launioncorp.com
ALLOWED_EMAILS=usuario@ejemplo.com

# ── URLs de despliegue (dejar vacío en local) ─────────────────────────────────
# Render/cloud: https://asistente-excel.onrender.com
WEBHOOK_URL=
ADDIN_URL=
