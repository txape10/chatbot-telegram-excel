# ── Bot de Telegram ───────────────────────────────────────────────────────────
TELEGRAM_TOKEN=token_obtenido_de_botfather
GROQ_API_KEY=clave_de_groq_console
AUTHORIZED_USERS=123456789,987654321

# ── API REST (Add-in Excel) ───────────────────────────────────────────────────
API_KEY=clave_secreta_del_addin

# ── Control de acceso al Add-in ───────────────────────────────────────────────
ALLOWED_DOMAINS=launioncorp.eu,launioncorp.com
ALLOWED_EMAILS=usuario@ejemplo.com,otro@ejemplo.com

# ── Cloud (Render/Railway) — dejar vacío en local ────────────────────────────
# URL pública del despliegue, sin barra final
# Ejemplo: https://asistente-excel.onrender.com
WEBHOOK_URL=

# URL donde se sirven los ficheros del Add-in (para el build de webpack)
# Ejemplo: https://asistente-excel.onrender.com/
ADDIN_URL=

# El proveedor cloud lo inyecta automáticamente — no hace falta definirlo
# PORT=8000
