# ════════════════════════════════════════════════════════════════════════════
#  .env.empresa.example — Plantilla para despliegue en servidor de empresa
#  Copiar a .env y rellenar los valores reales.
#  Este fichero SÍ va al repositorio; el .env real NO (está en .gitignore).
# ════════════════════════════════════════════════════════════════════════════

# ── Modo ──────────────────────────────────────────────────────────────────────
# "empresa" desactiva Telegram automáticamente y aplica defaults más estrictos
APP_MODE=empresa

# ── Módulos ───────────────────────────────────────────────────────────────────
# En modo empresa solo se necesita el Add-in; el bot queda desactivado.
# Si en el futuro se necesita el bot (p. ej. canal de notificaciones), activarlo aquí.
ENABLE_TELEGRAM=false
ENABLE_ADDIN=true

# ── Proveedor de IA ───────────────────────────────────────────────────────────
# Opciones recomendadas para empresa:
#   mistral  — gratuito, servidores en la UE, cumple RGPD
#   azure    — Azure OpenAI, datos en la UE, cumple RGPD, de pago

# Opción A — Mistral (recomendado para empezar, gratis en console.mistral.ai)
LLM_PROVIDER=mistral
LLM_MODEL=mistral-small-latest
MISTRAL_API_KEY=clave_de_mistral

# Opción B — Azure OpenAI (descomentar y rellenar si se usa Azure)
# LLM_PROVIDER=azure
# LLM_MODEL=gpt-4o-mini
# AZURE_OPENAI_KEY=clave_de_azure
# AZURE_OPENAI_URL=https://<recurso>.openai.azure.com
# AZURE_API_VERSION=2024-02-01

# Proveedor de respaldo (opcional, se activa si el principal falla)
# LLM_FALLBACK_PROVIDER=mistral
# LLM_FALLBACK_MODEL=

# ── Bot de Telegram (solo si ENABLE_TELEGRAM=true) ────────────────────────────
# TELEGRAM_TOKEN=token_de_botfather
# AUTHORIZED_USERS=id_telegram_admin

# ── Add-in Excel ──────────────────────────────────────────────────────────────
# Generar con: python -c "import secrets; print(secrets.token_hex(32))"
API_KEY=clave_secreta_del_addin

# Dominios corporativos con acceso (todos los usuarios de ese dominio)
ALLOWED_DOMAINS=empresa.eu,empresa.com

# Correos individuales adicionales (p. ej. admin externo, consultores)
ALLOWED_EMAILS=

# Nombre de la empresa — aparece en el selector de tema del Add-in
COMPANY_NAME=Mi Empresa

# ── Panel de administración ───────────────────────────────────────────────────
# Clave para acceder a /admin (si está vacía se usa API_KEY como fallback)
# Generar con: python -c "import secrets; print(secrets.token_hex(32))"
ADMIN_KEY=clave_secreta_del_admin

# Telegram ID del administrador que recibe alertas del sistema (opcional)
# Obtener con @userinfobot en Telegram
# ALERT_TELEGRAM_ID=

# ── URLs de despliegue ────────────────────────────────────────────────────────
# Servidor empresa Linux con acceso interno + cloudflared para exterior:
#   WEBHOOK_URL vacío  → el bot usa polling (solo si ENABLE_TELEGRAM=true)
#   ADDIN_URL          → URL pública del servidor para el Add-in
WEBHOOK_URL=
ADDIN_URL=https://asistente.empresa.eu

# ── Base de datos ─────────────────────────────────────────────────────────────
# Servidor empresa usa SQLite local — NO configurar Turso aquí.
# Turso es solo para Render/cloud donde el disco es efímero.
# TURSO_DATABASE_URL=   ← NO usar en servidor empresa
# TURSO_AUTH_TOKEN=     ← NO usar en servidor empresa
